---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order,
);
---
<Base title="Work — Shahzeb Jadoon" description="Selected edge-AI, hardware-software co-design, and autonomous-systems projects.">
  <section aria-labelledby="work-h" style="padding-top:2.5rem">
    <h1 id="work-h">Work</h1>
    <p class="lead">Selected projects across edge AI, hardware-software co-design, and
      autonomous systems. Each opens to a 3-level deep-dive: overview → approach → evidence.</p>
    <div class="cards reveal">
      {projects.map((p) => (
        <a class="card" href={`/work/${p.id}/`}>
          <h3>{p.data.title}</h3>
          {p.data.metrics[0] && (
            <p class="mono" style="color:var(--accent)">{p.data.metrics[0].value} · {p.data.metrics[0].label}</p>
          )}
          <p>{p.data.blurb}</p>
          <ul class="tags" aria-label="Technologies" style="margin-top:0.75rem">
            {p.data.tags.slice(0, 4).map((t) => <li>{t}</li>)}
          </ul>
        </a>
      ))}
    </div>
  </section>
</Base>
