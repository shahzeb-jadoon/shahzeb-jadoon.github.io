---
import '../styles/global.css';
import { site, nav } from '../data/site';
import Assistant from '../components/Assistant.astro';

interface Props {
  title?: string;
  description?: string;
  /** Set true only on the homepage so we emit the full ProfilePage/Person schema. */
  profilePage?: boolean;
  /** Absolute-or-root-relative path to a social preview image (og:image). */
  image?: string;
  /** Home page: full-bleed main + nav that reveals on scroll. */
  home?: boolean;
}

const {
  title = `${site.name} — ${site.role}`,
  description = site.tagline,
  profilePage = false,
  image,
  home = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, site.url).href;
const ogImage = image ? new URL(image, site.url).href : undefined;

const personLd = {
  '@type': 'Person',
  name: site.name,
  alternateName: site.alternateName,
  jobTitle: site.role,
  description: site.tagline,
  email: `mailto:${site.email}`,
  telephone: site.phoneE164,
  url: site.url,
  address: { '@type': 'PostalAddress', addressLocality: 'Rochester', addressRegion: 'NY', addressCountry: 'US' },
  sameAs: [site.github, site.linkedin],
  knowsAbout: site.knowsAbout,
  alumniOf: site.alumniOf.map((a) => ({ '@type': 'CollegeOrUniversity', name: a.name })),
};

const jsonLd = profilePage
  ? { '@context': 'https://schema.org', '@type': 'ProfilePage', mainEntity: personLd }
  : { '@context': 'https://schema.org', ...personLd };
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- Entity graph for AI crawlers (server-rendered into initial HTML) -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Mark JS-enabled before paint so reveal styles apply only with JS on
         (no-JS users and crawlers see fully-visible content). -->
    <script is:inline>document.documentElement.classList.add('js');</script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <!-- The nav is always visible — hide-until-scroll read as a glitch, and the
         bar anchors the page. Every link pairs a hand-drawn stroke icon with
         its label (icons live in src/data/site.ts next to the routes). -->
    <header class="nav">
      <div class="wrap">
        <p class="brand">
          <a href="/">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"
              stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 11l8-7 8 7" /><path d="M6 9.5V20h12V9.5" /><path d="M10 20v-6h4v6" />
            </svg>
            <span>Home</span>
          </a>
        </p>
        <nav aria-label="Primary">
          {nav.map((n) => (
            <a href={n.href}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"
                stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={n.icon} />
              <span>{n.label}</span>
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main id="main" class={home ? 'main-fluid' : 'wrap'}>
      <slot />
    </main>

    <footer>
      <div class="wrap">
        <p>© {new Date().getFullYear()} <a href={site.repo}>{site.name}</a></p>
        <p class="mono" style="font-size:0.8rem">Built with Astro · hosted on GitHub Pages · zero third-party backend.</p>
      </div>
    </footer>

    <Assistant />

    <script>
      // Reveal elements as they scroll into view (§4.3). Above-the-fold
      // elements are already intersecting, so they animate in on load.
      const io = new IntersectionObserver(
        (entries, obs) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('is-in');
              obs.unobserve(e.target);
            }
          }
        },
        { rootMargin: '0px 0px -6% 0px', threshold: 0.06 },
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
