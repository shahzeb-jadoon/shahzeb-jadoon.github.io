---
// In-browser "Ask my portfolio" assistant — baseline semantic search (§16.2).
// On first use it loads MiniLM from a CDN, embeds the visitor's question IN THEIR
// browser, and cosine-matches against /embeddings.json. No server, no API, no data
// leaves the page. Lazy: nothing loads until the panel is opened / a query is sent.
---
<div id="assistant">
  <button id="asst-toggle" class="asst-fab" aria-haspopup="dialog" aria-expanded="false" aria-controls="asst-panel">
    <span aria-hidden="true">◆</span> Ask my portfolio
  </button>

  <div id="asst-panel" class="asst-panel glass" role="dialog" aria-modal="true" aria-labelledby="asst-title" hidden>
    <div class="asst-head">
      <p id="asst-title" class="asst-title">Ask my portfolio</p>
      <button id="asst-close" class="asst-x" type="button" aria-label="Close">✕</button>
    </div>
    <form id="asst-form" class="asst-form">
      <label class="asst-sr" for="asst-input">Your question</label>
      <input id="asst-input" class="asst-input" type="text" autocomplete="off"
             placeholder="e.g. What did he do on neuromorphic hardware?" />
      <button class="asst-go" type="submit" aria-label="Search">→</button>
    </form>
    <div class="asst-modes">
      <button id="asst-ai" class="asst-ai" type="button" hidden>✨ Enable AI answers</button>
      <span id="asst-ai-note" class="asst-note" hidden>AI answers need a WebGPU browser (Chrome/Edge desktop).</span>
    </div>
    <p id="asst-status" class="asst-status" role="status" aria-live="polite"></p>
    <div class="asst-scroll-area">
      <div id="asst-answer-wrap" class="asst-answer-wrap" hidden>
        <p id="asst-answer" class="asst-answer" aria-live="polite"></p>
        <p class="asst-disclaimer">Generated in your browser from the excerpts below — verify against the linked pages.</p>
      </div>
      <div id="asst-results" class="asst-results"></div>
    </div>
    <p class="asst-foot">Runs entirely in your browser · nothing leaves this page.</p>
  </div>
</div>

<!-- global: result cards are created in JS and won't carry Astro's scope attribute -->
<style is:global>
  .asst-sr { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); }
  .asst-fab {
    position: fixed; right: 1.25rem; bottom: 1.25rem; z-index: 60;
    font-family: var(--mono); font-size: 0.85rem; color: var(--accent);
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    -webkit-backdrop-filter: blur(10px); backdrop-filter: blur(10px);
    border: 1px solid var(--glass-brd); border-radius: 999px;
    padding: 0.6rem 1rem; cursor: pointer; box-shadow: var(--shadow-glass);
  }
  .asst-fab:hover { border-color: var(--accent); }
  .asst-panel {
    position: fixed; right: 1.25rem; bottom: 4.5rem; z-index: 60;
    width: min(360px, calc(100vw - 2.5rem)); max-height: min(70vh, 520px);
    flex-direction: column; padding: 0.9rem;
  }
  .asst-panel:not([hidden]) { display: flex; }
  .asst-panel[hidden] { display: none; }
  .asst-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.6rem; }
  .asst-title { margin: 0; font-family: var(--mono); font-size: 0.9rem; color: var(--text); }
  .asst-x { background: transparent; border: 0; color: var(--text-dim); font-size: 1rem; cursor: pointer; line-height: 1; }
  .asst-x:hover { color: var(--text); }
  .asst-form { display: flex; gap: 0.4rem; }
  .asst-input {
    flex: 1; background: var(--bg); border: 1px solid var(--glass-brd); border-radius: 8px;
    color: var(--text); padding: 0.5rem 0.6rem; font-family: var(--sans); font-size: 0.9rem;
  }
  .asst-go { background: var(--accent); color: var(--accent-ink); border: 0; border-radius: 8px; padding: 0 0.8rem; font-size: 1rem; cursor: pointer; }
  .asst-status { margin: 0.5rem 0 0; font-family: var(--mono); font-size: 0.78rem; color: var(--text-mute); min-height: 1em; }
  .asst-scroll-area { flex: 1; min-height: 0; overflow-y: auto; padding-right: 0.2rem; }
  .asst-results { margin-top: 0.4rem; }
  .asst-result { display: block; text-decoration: none; color: inherit; border: 1px solid var(--glass-brd); border-radius: 8px; padding: 0.6rem 0.7rem; margin-bottom: 0.5rem; background: var(--glass-bg); }
  .asst-result:hover { border-color: var(--accent); }
  .asst-result b { font-size: 0.85rem; color: var(--text); display: block; }
  .asst-result span { font-size: 0.78rem; color: var(--text-dim); display: block; margin-top: 0.2rem; }
  .asst-foot { margin: 0.5rem 0 0; font-size: 0.72rem; color: var(--text-mute); font-family: var(--mono); }
  .asst-modes { display: flex; align-items: center; gap: 0.5rem; margin-top: 0.5rem; flex-wrap: wrap; }
  .asst-ai { font-family: var(--mono); font-size: 0.75rem; color: var(--accent-2); background: transparent; border: 1px solid var(--glass-brd); border-radius: 999px; padding: 0.3rem 0.7rem; cursor: pointer; }
  .asst-ai:hover { border-color: var(--accent-2); }
  .asst-ai:disabled { opacity: 0.6; cursor: default; }
  .asst-note { font-size: 0.72rem; color: var(--text-mute); font-family: var(--mono); }
  .asst-answer-wrap { margin-top: 0.6rem; border: 1px solid var(--glass-brd); border-radius: 8px; padding: 0.7rem; background: var(--glass-bg); }
  .asst-answer { margin: 0; font-size: 0.88rem; color: var(--text); line-height: 1.55; white-space: pre-wrap; }
  .asst-disclaimer { margin: 0.5rem 0 0; font-size: 0.7rem; color: var(--text-mute); font-family: var(--mono); }
</style>

<script>
  const toggle = document.getElementById('asst-toggle')!;
  const panel = document.getElementById('asst-panel')!;
  const closeBtn = document.getElementById('asst-close')!;
  const form = document.getElementById('asst-form') as HTMLFormElement;
  const input = document.getElementById('asst-input') as HTMLInputElement;
  const statusEl = document.getElementById('asst-status')!;
  const results = document.getElementById('asst-results')!;
  const aiBtn = document.getElementById('asst-ai') as HTMLButtonElement;
  const aiNote = document.getElementById('asst-ai-note')!;
  const answerWrap = document.getElementById('asst-answer-wrap')!;
  const answerEl = document.getElementById('asst-answer')!;

  let extractor: any = null;
  let index: any = null;
  let modelPromise: Promise<any> | null = null;

  // Opt-in generative tier (WebLLM, WebGPU) — grounded only in retrieved chunks.
  let genEnabled = false;
  let engine: any = null;
  let enginePromise: Promise<any> | null = null;
  const GEN_MODEL = 'Llama-3.2-1B-Instruct-q4f16_1-MLC';
  const SYS = [
    'You are a helpful assistant for Shahzeb Jadoon\'s engineering portfolio.',
    'Only discuss his technical work. If asked something unrelated to engineering, politely redirect.',
    'Answer the user\'s question concisely in EXACTLY 2-4 sentences using ONLY the facts from the provided Context.',
    'Include citations like [1] or [2] to reference the source.'
  ].join(' ');

  const setStatus = (t: string) => { statusEl.textContent = t || ''; };
  const dot = (a: number[], b: number[]) => { let s = 0; for (let i = 0; i < a.length; i++) s += a[i] * b[i]; return s; };

  async function ensureIndex() {
    if (index) return;
    const res = await fetch('/embeddings.json');
    if (!res.ok) throw new Error('index');
    index = await res.json();
  }

  function ensureModel() {
    if (!modelPromise) {
      modelPromise = (async () => {
        setStatus('Loading search model (~35 MB, first time)…');
        const t = await import(/* @vite-ignore */ 'https://cdn.jsdelivr.net/npm/@xenova/transformers@2.17.2');
        t.env.allowLocalModels = false;
        t.env.backends.onnx.wasm.numThreads = 1;
        // Model is taken from the index so the browser can never drift from the
        // model the vectors were built with (ensureIndex runs first in search()).
        const model = (index && index.model) || 'Xenova/bge-small-en-v1.5';
        extractor = await t.pipeline('feature-extraction', model);
        return extractor;
      })();
    }
    return modelPromise;
  }

  function ensureEngine() {
    if (!enginePromise) {
      enginePromise = (async () => {
        const webllm = await import(/* @vite-ignore */ 'https://esm.run/@mlc-ai/web-llm');
        engine = await webllm.CreateMLCEngine(GEN_MODEL, {
          initProgressCallback: (r: any) => setStatus(`Loading AI model… ${Math.round((r.progress || 0) * 100)}%`),
        });
        return engine;
      })();
    }
    return enginePromise;
  }

  async function generate(q: string, top: any[]) {
    try {
      answerWrap.hidden = false;
      answerEl.textContent = '';
      setStatus('Generating…');
      const context = top.map((c, i) => `[${i + 1}] ${c.title}: ${c.text}`).join('\n\n');
      const stream = await engine.chat.completions.create({
        messages: [
          { role: 'system', content: SYS },
          { role: 'user', content: `Context:\n${context}\n\nQuestion: ${q}` },
        ],
        temperature: 0,
        max_tokens: 350,
        stream: true,
      });
      for await (const chunk of stream) {
        answerEl.textContent += chunk.choices?.[0]?.delta?.content || '';
      }
    } catch (err) {
      console.error('[Assistant] WebGPU generate error:', err);
      answerEl.textContent = "The AI model encountered a hardware error (WebGPU memory limit). Please rely on the search results below.";
    }
  }

  function render(list: any[]) {
    results.innerHTML = '';
    if (!list.length) { setStatus('No matches found.'); return; }
    for (const r of list) {
      const a = document.createElement('a');
      a.className = 'asst-result';
      a.href = r.url;
      const b = document.createElement('b'); b.textContent = r.title;
      const norm = (x: string) => x.toLowerCase().replace(/[^a-z0-9]/g, '');
      let snip = r.text;
      const cut = snip.indexOf('. ');
      if (cut > 0 && norm(snip.slice(0, cut)) === norm(r.title)) snip = snip.slice(cut + 2);
      const s = document.createElement('span'); s.textContent = snip.slice(0, 130).trim() + '…';
      a.append(b, s);
      results.appendChild(a);
    }
  }

  async function search(q: string) {
    try {
      setStatus('Thinking…');
      await ensureIndex();
      await ensureModel();
      // Prefix + pooling must match how the index was built (both read from the index).
      const query = ((index && index.queryInstruction) || '') + q;
      const out = await extractor(query, { pooling: (index && index.pooling) || 'mean', normalize: true });
      const v = Array.from(out.data) as number[];
      const scored = index.chunks
        .map((c: any) => ({ c, s: dot(v, c.vector) }))
        .sort((a: any, b: any) => b.s - a.s);

      // Displayed cards: best-matching chunk per page (deduped by URL), max 4.
      const seen = new Set<string>();
      const pages: any[] = [];
      for (const { c } of scored) {
        if (seen.has(c.url)) continue;
        seen.add(c.url); pages.push(c);
        if (pages.length >= 4) break;
      }
      render(pages);

      // Generative context: top 3 chunks only — small models work better with
      // less context and clearer signal.
      if (genEnabled && engine) {
        const context = scored.slice(0, 3).map(({ c }) => c);
        await generate(q, context);
      } else {
        answerWrap.hidden = true;
      }
      setStatus('');
    } catch (err) {
      console.error('[Assistant] search error:', err);
      setStatus('Couldn\'t load the search just now — please try again.');
    }
  }

  function open() {
    panel.hidden = false;
    toggle.setAttribute('aria-expanded', 'true');
    input.focus();
    ensureIndex().catch(() => {});
  }
  function close() {
    panel.hidden = true;
    toggle.setAttribute('aria-expanded', 'false');
    toggle.focus();
  }

  toggle.addEventListener('click', () => (panel.hidden ? open() : close()));
  closeBtn.addEventListener('click', close);
  form.addEventListener('submit', (e) => { e.preventDefault(); const q = input.value.trim(); if (q) search(q); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !panel.hidden) close(); });
  document.addEventListener('click', (e) => {
    if (!panel.hidden && !panel.contains(e.target as Node) && !toggle.contains(e.target as Node)) close();
  });

  // Generative tier is offered only where WebGPU exists (desktop Chrome/Edge).
  if ('gpu' in navigator) {
    aiBtn.hidden = false;
    aiBtn.addEventListener('click', async () => {
      aiBtn.disabled = true;
      setStatus('Loading AI model (~0.9 GB, one-time)…');
      try {
        await ensureEngine();
        genEnabled = true;
        aiBtn.textContent = '✨ AI answers on';
        setStatus('AI answers enabled — ask a question.');
      } catch {
        setStatus('Couldn’t start the AI model. Using search results instead.');
        aiBtn.disabled = false;
      }
    });
  } else {
    aiNote.hidden = false;
  }
</script>
